@startuml

package "Partida" {
  rectangle "Controlador de lógica" as Logica
  folder "Tablero" {
    rectangle "Pieza"
    rectangle "Casilla"
    rectangle "Sistema de cámara"
  }
  folder "Interfaz" {
    rectangle "HUD"
    rectangle "Overlay"
    rectangle "Carta"
  }
}

package "Navegación" {
    rectangle "Menú"
}

package "Cliente" {
    rectangle "Cliente REST" as REST
    rectangle "Cliente WebSocket" as WS
}

package "Sistema de audio" {
    rectangle "Controlador de audio" as Audio
    rectangle "Bus" as Bus
}

' Suggested Relationships
Logica -- [Tablero] : Actualiza estado
Logica -- [Interfaz] : Actualiza interfaz
WS -- Logica : Intercambian eventos
[Interfaz] -- Audio : Sonidos de interfaz
[Tablero] -- Audio : Sonidos de partida
Audio -- Bus : Música y SFX
REST -- [Navegación]
[Navegación] -- Audio

@enduml
