@startuml
participant "Proponente" as P
participant "Receptor" as R

loop "not next_phase"

    P -> R : Proponer transacción
    activate P
    note right of P: Esperar respuesta
    
    alt Acepta
        R --> P : Acepta (aplicar transacción)
    else Rechaza (Timeout)
        R --> P : Rechaza
    end

end

deactivate R
@enduml
