@startuml

state "Tirar dados" as ini
state "Elección casilla" as elec
state "Gestión casilla" as cas
state "Negocios" as gest
state "Liquidación" as liq
state "Subasta" as subasta
state "Elección fantasía" as elec_fantasia

state fork_propiedad <<fork>>

state post_fork_propiedad <<fork>>

' Start point
[*] --> ini

' Main branch from "inicial"
' Timeout de no tirar dados: pierdes
ini --> elec : triple (triples = true)
ini --> elec : doble bus (dobles = true, streak++)
ini --> cas : dobles (dobles = true, streak++)
ini --> cas : normal (not cárcel)
ini --> liq : normal (cárcel)

' Elección
elec --> cas

' Casilla
cas --> fork_propiedad : propiedad
cas --> elec_fantasia : fantasía

elec_fantasia --> ini : dobles == true
elec_fantasia --> gest : dobles == false

' Propiedad
fork_propiedad --> post_fork_propiedad : Propiedad del jugador
fork_propiedad --> post_fork_propiedad : Propiedad ajena 
fork_propiedad --> post_fork_propiedad : Compra
fork_propiedad --> subasta : No compra

post_fork_propiedad --> gest : dobles == false
post_fork_propiedad --> ini : dobles == true

subasta --> ini : dobles == true
subasta --> gest : dobles == false


' Gestión
gest --> liq 

liq --> [*]

@enduml
